{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "include": ["src/**/*.ts"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "all": true
      },
      "nursery": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@xinas/probe": "src/agent/probe/* is agent-only; import from src/lib/parse/* instead.",
              "../agent/probe": "src/agent/probe/* is agent-only; import from src/lib/parse/* instead.",
              "../../agent/probe": "src/agent/probe/* is agent-only; import from src/lib/parse/* instead."
            }
          }
        }
      }
    }
  }
}
