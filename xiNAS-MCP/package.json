{
  "name": "xinas-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing xiNAS NAS infrastructure operations to AI assistants",
  "type": "module",
  "scripts": {
    "dev:api": "tsx src/api-server.ts",
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "mkdir -p dist/state/migrations && cp src/state/migrations/*.sql dist/state/migrations/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/api-server.js",
    "start:api": "node dist/api-server.js",
    "dev:agent": "tsx src/agent-server.ts",
    "start:agent": "node dist/agent-server.js",
    "lint": "biome lint src/",
    "format:check": "biome format src/",
    "format:write": "biome format --write src/",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:contracts": "vitest run src/__tests__/contracts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.5.0",
    "dbus-native": "^0.4.0",
    "express": "^5.1.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.7.0",
    "@biomejs/biome": "~1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "xinasctl": "dist/cli/xinasctl.js",
    "xinas-mcp-stdio": "dist/mcp-stdio.js"
  }
}
